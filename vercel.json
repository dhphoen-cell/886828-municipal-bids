{
  "version": 2,
  "output": "static",
  "git": {
    "deploymentEnabled": true
  },
  "routes": [
    {
      "src": "/bids\\.json",
      "dest": "/bids.json",
      "headers": {
        "content-type": "application/json",
        "cache-control": "public, max-age=60, must-revalidate"
      }
    },
    {
      "src": "/stats\\.json",
      "dest": "/stats.json",
      "headers": {
        "content-type": "application/json"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
