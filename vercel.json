{
  "version": 2,
  "builds": [
    {
      "src": "api/bids.py",
      "use": "@vercel/python"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.json",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/bids",
      "dest": "api/bids.py"
    },
    {
      "src": "/api/stats",
      "dest": "api/bids.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
